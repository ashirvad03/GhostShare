# 1. Compiled Class files
*.class

# 2. Log files
*.log

# 3. Package Files (Heavy Binaries - Strictly Restricted)
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
*.exe

# 4. Maven Output (Kachra aur Build files)
target/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# 5. IDE Specific Folders (Developer Machine specific)
.idea/
*.iml
.vscode/
.classpath
.project
.settings/

# 6. GhostShare Custom Output Folders
OutputEXE/
make_ghost.bat

# 7. OS Generated Files
Thumbs.db
.DS_Store
